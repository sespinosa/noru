{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "noru",
  "version": "0.1.0",
  "identifier": "com.noru.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "noru",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "visible": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
